# ALMACENAMIENTO DE FOTOS (modo local — sin IMAGE_SERVICE_URL)
# En desarrollo local: se usa por defecto uploads/fotos/
# En producción (Hostinger): descomenta y configura la ruta absoluta
UPLOADS_PATH=/home/username/public_html/uploads

# IMAGE SERVICE — Servicio externo para fotos y materiales
# Si está configurado, la API enviará fotos y materiales a este servicio.
# La BD guardará la URL completa devuelta por el servicio.
# El image-service debe estar corriendo en la URL indicada.
IMAGE_SERVICE_URL=https://intranet-cec-image-service.onrender.com
# (Localmente: IMAGE_SERVICE_URL=http://localhost:4000)
